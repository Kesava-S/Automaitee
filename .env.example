# Automaitee Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Google Apps Script Integration ────────────────────────────────────────────

# Server-side only — never exposed to the browser.
# Go to: Apps Script editor → Deploy → New deployment → Web App → Copy URL
# Access must be set to "Anyone".
APPSCRIPT_URL=https://script.google.com/macros/s/AKfycby7t3caIwJY1QwsE1B_NH4ZGOQzBUI6thGtCyKT32V61y0IG-prHH-h0Zr0qcyqW2lIvQ/exec
# Client-side flag — tells the browser that the Sheets backend is active.
# The browser calls /api/sheets (same-origin proxy); it never sees APPSCRIPT_URL.
NEXT_PUBLIC_SHEETS_ENABLED=true

# ── Notes ─────────────────────────────────────────────────────────────────────
# If APPSCRIPT_URL is not set, the portal runs in localStorage-only demo mode.
# All data is stored in the browser — suitable for development and demos.
#
# Google Sheet setup:
#   Sheet name:  Automaitee Digital
#   Headers:     userid | email | temporaryPassword | customPassword |
#                passwordChanged | tcAccepted | tcAcceptedName | tcAcceptedDate |
#                onboardingComplete | accountStatus | createdAt |
#                name | company | plan | contractExpiryDate |
#                dueNotification | customServices
#
# Run setupSheets() once in the Apps Script editor to create all sheets.
